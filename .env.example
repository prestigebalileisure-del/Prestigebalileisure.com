# Strapi Configuration
# Add your Strapi Cloud URL here
NEXT_PUBLIC_STRAPI_URL=https://your-strapi-cloud-instance.com

# Strapi API Token
# Generate this from Strapi Admin -> Settings -> API Tokens
NEXT_PUBLIC_STRAPI_API_TOKEN=your_api_token_here

# Instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Update values with your actual Strapi credentials
# 3. NEVER commit .env.local to GitHub
# 4. Add environment variables to Vercel dashboard for production
